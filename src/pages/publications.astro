---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslation, type Language } from '../utils/i18n';
import I18nPair from '../components/I18nPair.astro';
import PublicationsSection from '../components/PublicationsSection';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'ta';

/** Blurb Books UK — TMK 40th year souvenir (print-on-demand publisher) */
const BLURB_40TH_SOUVENIR =
  'https://www.blurb.co.uk/books/6840280-40-t-m-k-40th-year-souvenir';

const PUBLICATION_THUMB_DIR = path.join(process.cwd(), 'public', 'static', 'content', 'publications');

function thumbnailPublicUrl(file: string) {
  return `/static/content/publications/${file}`;
}

function resolveThumbnailSrc(file: string | null): string | null {
  if (!file) return null;
  const abs = path.join(PUBLICATION_THUMB_DIR, file);
  return fs.existsSync(abs) ? thumbnailPublicUrl(file) : null;
}

/** Shown when R2 manifest is empty or API fails (dev). Live site uses /admin/publications when manifest has items. */
const fallbackPublications = [
  {
    id: 'fallback-blurb-40th',
    publisher: 'Blurb Books UK',
    publisherNoteTa: 'அச்சிடப்பட்ட புத்தகங்கள் · இணைய விற்பனை',
    publisherNoteEn: 'Print-on-demand books · Online bookstore',
    titleTa: '40 T.M.K. — 40-வது ஆண்டு நினைவிதழ்',
    titleEn: '40 T.M.K. — 40th Year Souvenir',
    href: BLURB_40TH_SOUVENIR,
    ctaTa: 'Blurb இல் பார்க்க',
    ctaEn: 'View on Blurb',
    coverKey: null as string | null,
    thumbnailAltTa: '40-வது ஆண்டு நினைவிதழ் — முன்பக்க முன்னோட்டம்',
    thumbnailAltEn: '40th year souvenir — cover / first page preview',
    thumbnailSrc: resolveThumbnailSrc('tmk-40th-souvenir-cover.jpg'),
  },
];
---

<BaseLayout 
  title={getTranslation('publications', 'ta')}
  titleEn={getTranslation('publications', 'en')}
  description="TMK London publications — Tamil literature and cultural resources. 40th year souvenir via Blurb Books UK."
  lang={lang}
>
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold mb-8 text-center font-tamil">
          <span class="i18n-ta">{getTranslation('publications', 'ta')}</span><span class="i18n-en">{getTranslation('publications', 'en')}</span>
        </h1>

        <p class="text-gray-700 leading-relaxed mb-10 text-center max-w-2xl mx-auto font-tamil">
          <I18nPair
            block
            ta="எங்கள் பதிப்புகள் மற்றும் வெளியீட்டாளர்களுடன் இணைந்த தளங்களை இங்கே காணலாம்."
            en="Browse our publications and publisher partners where our titles are available."
          />
        </p>

        <PublicationsSection client:load fallbackPublications={fallbackPublications} />

        <div class="bg-white rounded-lg shadow-lg p-8">
          <p class="text-gray-700 leading-relaxed font-tamil text-center text-sm">
            <I18nPair block ta="மேலும் பதிப்புகள் விரைவில் சேர்க்கப்படும்." en="More publications will be added soon." />
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
