---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslation, type Language } from '../utils/i18n';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'ta';
---

<BaseLayout 
  title={getTranslation('studentRegistration', lang)}
  description="Register your child for TMK Tamil School. Join our Tamil language and culture classes in London."
  lang={lang}
>
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold mb-8 text-center font-tamil">
          {getTranslation('studentRegistration', lang)}
        </h1>
        
        <div class="bg-white rounded-lg shadow-lg p-8 mb-8">
          <p class="text-gray-700 leading-relaxed mb-6 font-tamil">
            {lang === 'ta' 
              ? 'TMK தமிழ்ப் பள்ளியில் பதிவு செய்ய, தயவுசெய்து கீழ்க்கண்ட விவரங்களுடன் தொடர்பு கொள்ளவும்:'
              : 'To register at TMK Tamil School, please contact us with the following details:'}
          </p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-8">
          <h2 class="text-2xl font-bold mb-4 font-tamil">
            {lang === 'ta' ? 'தொடர்பு விவரங்கள்' : 'Contact Details'}
          </h2>
          <div class="space-y-4">
            <p class="text-gray-700">
              <strong>{lang === 'ta' ? 'தலைமை ஆசிரியை:' : 'Head Teacher:'}</strong> +44 7340 077673
            </p>
            <p class="text-gray-700">
              <strong>{lang === 'ta' ? 'பள்ளி ஒருங்கினணப்பாளர்:' : 'School Coordinator:'}</strong> +44 7725 049347
            </p>
            <p class="text-gray-700">
              <strong>{lang === 'ta' ? 'மின்னஞ்சல்:' : 'Email:'}</strong> tmktamilschool@gmail.com
            </p>
            <p class="text-gray-700">
              <strong>{lang === 'ta' ? 'தொலைபேசி:' : 'Phone:'}</strong> +44 7459 528739
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
