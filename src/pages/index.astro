---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslation, type Language } from '../utils/i18n';
import { getLocalBusinessSchema } from '../utils/seo';
import HeroSection from '../components/HeroSection.astro';
import EventCard from '../components/EventCard.astro';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'ta';
const schoolSchema = getLocalBusinessSchema();

// Events data
const events = [
  {
    date: 'Dec 15, 2024',
    title: {
      ta: 'பொங்கல் கொண்டாட்டம்',
      en: 'Pongal Celebration'
    },
    description: {
      ta: 'பாரம்பரிய பொங்கல் விழாவில் எங்களுடன் சேரவும்',
      en: 'Join us for traditional Pongal festivities'
    }
  },
  {
    date: 'Dec 20, 2024',
    title: {
      ta: 'தமிழ் மொழி பட்டறை',
      en: 'Tamil Language Workshop'
    },
    description: {
      ta: 'தமிழ் எழுத்து மற்றும் உரையாடலை கற்றுக்கொள்ளுங்கள்',
      en: 'Learn Tamil script and conversation'
    }
  },
  {
    date: 'Jan 5, 2025',
    title: {
      ta: 'கலாச்சார நடன நிகழ்ச்சி',
      en: 'Cultural Dance Performance'
    },
    description: {
      ta: 'மாணவர்களின் பரதநாட்டியம் நிகழ்ச்சி',
      en: 'Bharatanatyam showcase by students'
    }
  }
];
---

<BaseLayout 
  title="Home" 
  description="Thamizhar Munnetra Kazhagam (TMK) London - Tamil School and Community Organization serving the Tamil community in London, UK"
  lang={lang}
  schema={schoolSchema}
>
  <!-- Hero Section with LTS-style design -->
  <HeroSection lang={lang} />

  <!-- Upcoming Events Section (Below Hero) -->
  <section id="activities" class="py-20 bg-gradient-to-br from-gray-50 to-primary-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-center mb-4 font-tamil">
        {getTranslation('upcomingEvent', lang)}
      </h2>
      <p class="text-center text-gray-600 mb-12 text-lg">
        {lang === 'ta' ? 'வரவிருக்கும் நிகழ்வுகளைப் பார்க்கவும்' : 'Check out our upcoming events'}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {events.map((event) => (
          <EventCard {...event} lang={lang} />
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/activities" class="inline-flex items-center px-6 py-3 bg-primary text-white rounded-lg font-semibold hover:bg-primary-dark transition-all shadow-md hover:shadow-lg">
          {lang === 'ta' ? 'அனைத்து நிகழ்வுகளையும் பார்க்க' : 'View All Events'}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="py-20 text-white" style="background: linear-gradient(to right, #0f766e, #0d9488);">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-6 font-tamil">
          {getTranslation('getInTouch', lang)}
        </h2>
        <p class="text-xl text-white/95 mb-8 leading-relaxed">
          {lang === 'ta' 
            ? 'நம்முடன் இணைந்து தமிழ் சமூகத்தின் முன்னேற்றத்திற்கு பங்களிக்கவும்'
            : 'Join us and contribute to the progress of the Tamil community'}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`/contact${lang === 'en' ? '?lang=en' : ''}`} class="bg-white text-primary px-8 py-4 rounded-lg font-semibold hover:bg-gray-50 transition-all shadow-md hover:shadow-lg border border-gray-300">
            {getTranslation('contact', lang)}
          </a>
          <a href="tel:+447459528739" class="text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-dark transition-all shadow-md hover:shadow-lg"
            style="background: #0f766e;"
          >
            {lang === 'ta' ? '📞 +44 7459 528739' : '📞 Call Us'}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
