---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslation, type Language } from '../utils/i18n';
import {
  getLocalBusinessSchema,
  getLocalBusinessSchemaForSEO,
  getWebSiteSchema,
  getHomepageFAQSchema,
} from '../utils/seo';
import HeroSection from '../components/HeroSection.astro';
import I18nPair from '../components/I18nPair.astro';
import UpcomingEventsSection from '../components/UpcomingEventsSection';
import { getFirstHeroSlideImageUrl } from '../config/hero-backgrounds';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'ta';
const firstHeroImageUrl = getFirstHeroSlideImageUrl();
const schoolSchema = getLocalBusinessSchema();
const localBusinessSchema = getLocalBusinessSchemaForSEO();
const webSiteSchema = getWebSiteSchema();
const faqSchema = getHomepageFAQSchema();
---

<BaseLayout
  description="London Tamil community & Tamil school in Manor Park, East London since 1975. TMK London: Tamil classes, culture & Tamil sangam. Tamil London · Tamil UK · learn Tamil."
  lang={lang}
  schema={[webSiteSchema, faqSchema, schoolSchema, localBusinessSchema]}
>
  <link
    slot="head-extra"
    rel="preload"
    as="image"
    href={firstHeroImageUrl}
    fetchpriority="high"
  />
  <!-- Hero Section with LTS-style design -->
  <HeroSection />

  <!-- Upcoming events: KV via /api/upcoming-events; local dev uses public/upcoming-events.json (see astro proxy) -->
  <UpcomingEventsSection client:load />

  <!-- Contact CTA Section -->
  <section class="py-16 md:py-24 text-white theme-section-cta">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-5 font-tamil">
          <span class="i18n-ta">{getTranslation('getInTouch', 'ta')}</span><span class="i18n-en">{getTranslation('getInTouch', 'en')}</span>
        </h2>
        <p class="text-lg md:text-xl text-white/95 mb-8 leading-relaxed">
          <I18nPair
            block
            ta="நம்முடன் இணைந்து தமிழ் சமூக கல்வி மற்றும் முன்னேற்றத்திற்கு பங்களிக்கவும்"
            en="Join us and support Tamil community education and progress"
          />
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" data-preserve-lang class="bg-white text-primary px-8 py-4 rounded-xl font-semibold hover:bg-gray-50 transition-all shadow-lg hover:shadow-xl border-0">
            <span class="i18n-ta">{getTranslation('contact', 'ta')}</span><span class="i18n-en">{getTranslation('contact', 'en')}</span>
          </a>
          <a href="tel:+447459528739" class="bg-white/15 hover:bg-white/25 text-white px-8 py-4 rounded-xl font-semibold transition-all border border-white/30">
            <span class="i18n-ta">📞 +44 7459 528739</span><span class="i18n-en">📞 Call Us</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
