---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslation, type Language } from '../utils/i18n';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'ta';
---

<BaseLayout 
  title={getTranslation('gallery', lang)}
  description="View photos and videos from TMK London events, Tamil school activities, and community gatherings."
  lang={lang}
>
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold mb-8 text-center font-tamil">
          {getTranslation('gallery', lang)}
        </h1>
        
        <div class="bg-white rounded-lg shadow-lg p-8">
          <p class="text-gray-700 leading-relaxed mb-6 font-tamil">
            {lang === 'ta' 
              ? 'விரைவில் சேர்க்கப்படும்'
              : 'Coming soon'}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
