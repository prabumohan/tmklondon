---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslation, type Language } from '../utils/i18n';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'ta';

// Gallery sections configuration
const gallerySections = [
  {
    id: 'teachers',
    titleTa: 'எங்கள் ஆசிரியர்கள்',
    titleEn: 'Our Teachers',
    descTa: 'எங்கள் அர்ப்பணிப்புள்ள ஆசிரியர்கள் தமிழ் மொழி மற்றும் கலாச்சாரத்தை கற்பிக்கும் பணியில் ஈடுபட்டுள்ளனர்.',
    descEn: 'Our dedicated teachers are committed to teaching Tamil language and culture.',
  },
  {
    id: 'school',
    titleTa: 'பள்ளி நடவடிக்கைகள்',
    titleEn: 'School Activities',
    descTa: 'மாணவர்கள் கற்றல், விளையாட்டு மற்றும் கலாச்சார நிகழ்ச்சிகளில் ஈடுபடுகின்றனர்.',
    descEn: 'Students engaged in learning, sports and cultural activities.',
  },
  {
    id: 'events',
    titleTa: 'நிகழ்வுகள்',
    titleEn: 'Events',
    descTa: 'தமிழர் திருநாள், பொங்கல் மற்றும் பிற கலாச்சார விழாக்கள்.',
    descEn: 'Tamil New Year, Pongal and other cultural celebrations.',
  },
  {
    id: 'community',
    titleTa: 'சமூக கூட்டங்கள்',
    titleEn: 'Community Gatherings',
    descTa: 'லண்டனில் உள்ள தமிழ் சமூகத்தின் ஒன்று கூடல்கள்.',
    descEn: 'Gatherings of the Tamil community in London.',
  }
];
---

<BaseLayout 
  title={getTranslation('gallery', lang)}
  description="London Tamil Sangam gallery – photos and videos from TMK London events, Tamil school activities, and Tamil Sangam community gatherings."
  lang={lang}
>
  <!-- Hero Section -->
  <section class="relative py-16 md:py-20" style="background: linear-gradient(135deg, #1e3a5f 0%, #162d49 50%, #2a4a6f 100%);">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white font-tamil">
          {getTranslation('gallery', lang)}
        </h1>
        <p class="text-lg md:text-xl text-white/90 font-tamil">
          {lang === 'ta' 
            ? 'எங்கள் நிகழ்வுகள், பள்ளி நடவடிக்கைகள் மற்றும் சமூக கூட்டங்களின் புகைப்படங்கள்'
            : 'Photos from our events, school activities, and community gatherings'}
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery Navigation -->
  <section class="sticky top-0 z-40 bg-white shadow-md">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-center space-x-2 md:space-x-4 py-4 overflow-x-auto scrollbar-hide">
        {gallerySections.map((section) => (
          <a 
            href={`#${section.id}`}
            class="gallery-nav-link px-4 py-2 text-sm md:text-base font-medium text-gray-700 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-all whitespace-nowrap"
            data-section={section.id}
          >
            {lang === 'ta' ? section.titleTa : section.titleEn}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Sections -->
  {gallerySections.map((section, sectionIndex) => (
    <section id={section.id} class={`py-12 md:py-16 ${sectionIndex % 2 === 0 ? 'bg-gray-50' : 'bg-white'}`}>
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <!-- Section Header -->
          <div class="text-center mb-10">
            <h2 class="text-3xl md:text-4xl font-bold mb-4 font-tamil text-gray-800">
              {lang === 'ta' ? section.titleTa : section.titleEn}
            </h2>
            <p class="text-gray-600 max-w-2xl mx-auto font-tamil">
              {lang === 'ta' ? section.descTa : section.descEn}
            </p>
          </div>

          <!-- Image Grid (populated by JavaScript) -->
          <div 
            id={`gallery-grid-${section.id}`}
            class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6"
            data-category={section.id}
          >
            <!-- Images will be loaded dynamically -->
            <div class="gallery-placeholder col-span-full text-center py-12 text-gray-400">
              <svg class="w-16 h-16 mx-auto mb-4 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p>{lang === 'ta' ? 'படங்களை ஏற்றுகிறது...' : 'Loading images...'}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Call to Action -->
  <section class="py-16 bg-gradient-to-r from-primary-600 to-primary-700">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-tamil">
        {lang === 'ta' ? 'உங்கள் புகைப்படங்களை பகிரவும்!' : 'Share Your Photos!'}
      </h2>
      <p class="text-white/90 mb-6 max-w-2xl mx-auto">
        {lang === 'ta' 
          ? 'நீங்கள் எங்கள் நிகழ்வுகளில் எடுத்த புகைப்படங்களை எங்களுக்கு அனுப்பலாம்'
          : 'Send us photos you\'ve taken at our events'}
      </p>
      <a 
        href={`/contact${lang === 'en' ? '?lang=en' : ''}`}
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary-600 font-bold rounded-xl hover:bg-gray-100 transition-all shadow-lg hover:shadow-xl"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {lang === 'ta' ? 'தொடர்பு கொள்ளுங்கள்' : 'Contact Us'}
      </a>
    </div>
  </section>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 hidden items-center justify-center p-4">
    <button id="lightbox-close" class="absolute top-4 right-4 text-white text-4xl hover:text-gray-300 transition-colors z-10">&times;</button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-gray-300 transition-colors z-10 p-2">&#8249;</button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-gray-300 transition-colors z-10 p-2">&#8250;</button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" />
  </div>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  // Gallery image loading and display
  const lang = new URLSearchParams(window.location.search).get('lang') || 'ta';
  
  interface GalleryImage {
    id: string;
    src: string;
    category: string;
    title: string;
  }
  
  let allImages: GalleryImage[] = [];
  let currentLightboxIndex = 0;
  let currentLightboxCategory = '';

  async function loadGalleryImages() {
    try {
      const res = await fetch('/api/gallery');
      if (res.ok) {
        const data = await res.json();
        if (Array.isArray(data) && data.length > 0) {
          allImages = data.map(function (item) {
            return { id: item.id, src: item.url, category: item.category, title: item.filename || 'Image' };
          });
          renderGalleryGrids();
          return;
        }
      }
    } catch (e) {
      console.error('Error loading gallery from API:', e);
    }
    const stored = localStorage.getItem('galleryImages');
    if (stored) {
      try {
        const parsed = JSON.parse(stored);
        allImages = Array.isArray(parsed) ? parsed.map(function (i) { return { id: i.id, src: i.src, category: i.category, title: i.title || '' }; }) : [];
      } catch (e) {
        allImages = [];
      }
    }
    renderGalleryGrids();
  }

  function renderGalleryGrids() {
    // Populate each category grid
    const categories = ['teachers', 'school', 'events', 'community'];
    categories.forEach(category => {
      const grid = document.getElementById(`gallery-grid-${category}`);
      if (!grid) return;

      const categoryImages = allImages.filter(img => img.category === category);
      
      // Clear placeholder
      grid.innerHTML = '';

      if (categoryImages.length === 0) {
        grid.innerHTML = `
          <div class="col-span-full text-center py-12">
            <div class="inline-block p-8 bg-gradient-to-br from-primary-400/20 to-primary-600/20 rounded-2xl">
              <svg class="w-16 h-16 mx-auto text-primary-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-gray-500 font-medium">${lang === 'ta' ? 'புகைப்படங்கள் விரைவில் சேர்க்கப்படும்' : 'Photos coming soon'}</p>
            </div>
          </div>
        `;
        return;
      }

      categoryImages.forEach((image, index) => {
        const div = document.createElement('div');
        div.className = 'group relative aspect-square overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 cursor-pointer';
        div.innerHTML = `
          <img 
            src="${image.src}" 
            alt="${image.title}"
            class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-300 flex items-center justify-center">
            <svg class="w-10 h-10 text-white opacity-0 group-hover:opacity-100 transition-all duration-300 transform scale-50 group-hover:scale-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
            </svg>
          </div>
        `;
        div.addEventListener('click', () => openLightbox(category, index));
        grid.appendChild(div);
      });
    });
  }

  function openLightbox(category, index) {
    currentLightboxCategory = category;
    currentLightboxIndex = index;
    updateLightboxImage();
    
    const lightbox = document.getElementById('lightbox');
    if (lightbox) {
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
    }
  }

  function closeLightbox() {
    const lightbox = document.getElementById('lightbox');
    if (lightbox) {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    }
  }

  function updateLightboxImage() {
    const categoryImages = allImages.filter(img => img.category === currentLightboxCategory);
    if (categoryImages.length === 0) return;
    
    const img = document.getElementById('lightbox-img') as HTMLImageElement;
    if (img && categoryImages[currentLightboxIndex]) {
      img.src = categoryImages[currentLightboxIndex].src;
      img.alt = categoryImages[currentLightboxIndex].title;
    }
  }

  function nextImage() {
    const categoryImages = allImages.filter(img => img.category === currentLightboxCategory);
    currentLightboxIndex = (currentLightboxIndex + 1) % categoryImages.length;
    updateLightboxImage();
  }

  function prevImage() {
    const categoryImages = allImages.filter(img => img.category === currentLightboxCategory);
    currentLightboxIndex = (currentLightboxIndex - 1 + categoryImages.length) % categoryImages.length;
    updateLightboxImage();
  }

  // Event listeners
  document.addEventListener('DOMContentLoaded', () => {
    loadGalleryImages();

    // Lightbox controls
    document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
    document.getElementById('lightbox-prev')?.addEventListener('click', prevImage);
    document.getElementById('lightbox-next')?.addEventListener('click', nextImage);
    
    // Close on background click
    document.getElementById('lightbox')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeLightbox();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      const lightbox = document.getElementById('lightbox');
      if (!lightbox || lightbox.classList.contains('hidden')) return;
      
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextImage();
      if (e.key === 'ArrowLeft') prevImage();
    });
  });

  // Listen for storage changes (when admin uploads new images)
  window.addEventListener('storage', (e) => {
    if (e.key === 'galleryImages') {
      loadGalleryImages();
    }
  });
</script>
