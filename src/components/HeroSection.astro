---

// Full-screen hero background – scrolling through these images (position = background-position for crop/focus)
// Images are loaded from R2 via /api/hero/image/ (falls back to static if R2 not configured)
const carouselImages: { src: string; position?: string }[] = [
  { src: '/api/hero/image/london-skyline-sunset.jpg' },
  { src: '/api/hero/image/background-london.jpg' },
  { src: '/api/hero/image/london-skyline-colorful.png' },
  { src: '/api/hero/image/hero-banner.jpg' },
  { src: '/api/hero/image/fiery_sunset_sky_swirling-full.jpg' },
  { src: '/api/hero/image/banner-tam-2.jpg', position: 'left center' }, // crop to show circular image on left
];

// YouTube video on the right. Default shown here; admin can override via Dashboard (stored in localStorage as heroYoutubeVideoId).
const youtubeVideoId = 'dqw9Eto_3JU';

// Riyadh-style: 4 stats in a row
const stats = [
  {
    value: '50+',
    label: { ta: 'சேவை ஆண்டுகள்', en: 'Years of Service' }
  },
  {
    value: '400+',
    label: { ta: 'சமூக உறுப்பினர்கள்', en: 'Community Members' }
  },
  {
    value: '1',
    label: { ta: 'பள்ளி இடம்', en: 'School Location' }
  },
  {
    value: '100+',
    label: { ta: 'நிகழ்வுகள்', en: 'Events Organised' }
  }
];
---

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-2 md:pt-4 pb-16 md:pb-20">
  <!-- Full-screen background carousel – text and logo sit in front -->
  <div class="absolute inset-0 z-0 hero-bg-slides" id="hero-bg-slides">
    {carouselImages.map((slide, index) => (
      <div
        class={`hero-bg-slide absolute inset-0 transition-opacity duration-[1500ms] ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-slide-index={index}
        style={`background-image: url(${slide.src}); background-size: cover; background-position: ${slide.position ?? 'center'};`}
        aria-hidden={index !== 0}
      />
    ))}
    <div class="absolute inset-0 hero-overlay z-20 pointer-events-none" style="background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(80, 35, 30, 0.4) 40%, rgba(25, 18, 18, 0.75) 85%, rgba(12, 10, 10, 0.88) 100%);"></div>
  </div>

  <!-- Logo: on desktop only (lg+) so mobile has no overlap/clipping). Header shows logo on all sizes. -->
  <a href="/" class="absolute left-16 xl:left-24 top-[35%] -translate-y-1/2 z-30 hero-logo-link group hidden lg:block" aria-label="TMK London - Home">
    <img src="/logo.png" alt="TMK London - London Tamil Sangam" class="w-72 lg:w-72 xl:w-80 h-72 lg:h-72 xl:h-80 rounded-full object-cover transition-transform duration-300 group-hover:scale-105" width="320" height="320" loading="eager" decoding="async" />
  </a>

  <!-- YouTube desktop: fixed at right, aligned with logo (top 35%). Hidden on mobile. -->
  {youtubeVideoId && (
    <div class="absolute right-4 sm:right-6 lg:right-8 xl:right-12 top-[35%] -translate-y-1/2 z-20 hidden lg:block w-72 xl:w-80" data-hero-video-container>
      <div class="rounded-2xl overflow-hidden shadow-2xl ring-2 ring-white/10 aspect-video bg-black">
        <iframe
          class="hero-youtube-embed w-full h-full"
          title="TMK London YouTube"
          src={`https://www.youtube.com/embed/${youtubeVideoId}?autoplay=1&mute=1&loop=1&playlist=${youtubeVideoId}&playsinline=1&rel=0`}
          data-video-id={youtubeVideoId}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
    </div>
  )}

  <!-- Content: centered. On mobile no hero logo so less top padding; on desktop logo is left. -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 flex flex-col items-center justify-center pt-24 sm:pt-28 lg:pt-0">
    <div class="flex flex-col items-center text-center w-full max-w-2xl text-white">
      <p class="text-sm md:text-base font-medium tracking-[0.2em] uppercase text-white/90 mb-5 md:mb-6 leading-snug min-h-[1.5em]">
        [ <span class="i18n-ta">நிறுவப்பட்டது 1975 · லண்டன், UK</span><span class="i18n-en">Est. 1975 · London, UK</span> ]
      </p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-1 mt-0">
        <span class="i18n-ta block font-tamil">வணக்கம்!</span>
        <span class="i18n-en block">Welcome to Thamizhar Munnetra Kazhagam</span>
      </h1>
      <p class="text-xl md:text-2xl font-tamil text-white/95 mb-2">
        <span class="i18n-ta">
          <span class="font-semibold text-amber-300 drop-shadow-sm" style="text-shadow: 0 0 20px rgba(251, 191, 36, 0.4);">தமிழர் முன்னேற்றக் கழகம்</span>
          {' '}லண்டன் தங்களை அன்புடன் வரவேற்கிறது
        </span>
        <span class="i18n-en">Thamizhar Munnetra Kazhagam – TMK London welcomes you</span>
      </p>

    <!-- Tagline (bilingual) -->
    <p class="text-base md:text-lg lg:text-xl text-white/90 max-w-3xl mx-auto mb-4 leading-relaxed">
      <span class="i18n-ta">1975 முதல் லண்டனில் தமிழ் மொழி, இலக்கியம் மற்றும் கலாச்சாரத்தை வளர்க்கிறோம்</span>
      <span class="i18n-en">Promoting Tamil language, literature & culture in London since 1975</span>
    </p>

    <!-- Inspirational quote (Riyadh-style) -->
    <p class="text-sm md:text-base italic text-white/85 max-w-2xl mx-auto mb-8 md:mb-10">
      "<span class="i18n-ta">தமிழருடன் தமிழில் பேசி, நம் தாய் மொழியைச் சிறப்பிப்போமாக!</span><span class="i18n-en">Let us speak Tamil with Tamilians and glorify our mother tongue!</span>"
    </p>

    <!-- Primary links: About Us | Our Events (Riyadh-style: primary = maroon) -->
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6 mb-10 md:mb-12">
      <a
        href="/about"
        data-preserve-lang
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold bg-white/15 backdrop-blur-md border border-white/30 hover:bg-white/25 transition-all text-white"
      >
        <span class="i18n-ta">எங்களைப் பற்றி</span><span class="i18n-en">About Us</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
      <a
        href="#activities"
        data-preserve-lang
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold bg-accent text-white border border-accent-dark hover:bg-accent-dark transition-all shadow-lg"
      >
        <span class="i18n-ta">எங்கள் நிகழ்வுகள்</span><span class="i18n-en">Our Events</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>

    <!-- YouTube mobile: in-flow below CTAs, slightly up. Hidden on desktop (lg+ has absolute version). -->
    {youtubeVideoId && (
      <div class="w-full max-w-sm mx-auto mt-4 mb-2 lg:hidden flex-shrink-0" data-hero-video-container>
        <div class="rounded-2xl overflow-hidden shadow-2xl ring-2 ring-white/10 aspect-video bg-black">
          <iframe
            class="hero-youtube-embed w-full h-full"
            title="TMK London YouTube"
            src={`https://www.youtube.com/embed/${youtubeVideoId}?autoplay=1&mute=1&loop=1&playlist=${youtubeVideoId}&playsinline=1&rel=0`}
            data-video-id={youtubeVideoId}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      </div>
    )}

    <!-- Stats row: 4 cards (Riyadh-style) -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 max-w-4xl mx-auto">
      {stats.map((stat) => (
        <div class="bg-black/35 backdrop-blur-md rounded-2xl p-5 md:p-6 border border-white/15 hover:bg-black/45 transition-all duration-300 hover:scale-[1.02] shadow-lg">
          <div class="text-3xl md:text-4xl lg:text-5xl font-bold text-amber-400" data-stat-value={stat.value}>
            {stat.value}
          </div>
          <div class="text-sm md:text-base text-white/90 font-medium mt-2">
            <span class="i18n-ta">{stat.label.ta}</span><span class="i18n-en">{stat.label.en}</span>
          </div>
        </div>
      ))}
    </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Use admin-set hero video ID from localStorage if present (updates both mobile and desktop iframes)
    const savedId = typeof window !== 'undefined' && window.localStorage && window.localStorage.getItem('heroYoutubeVideoId');
    if (savedId) {
      document.querySelectorAll('.hero-youtube-embed').forEach((iframe) => {
        if (iframe.getAttribute('data-video-id') !== savedId) {
          iframe.src = `https://www.youtube.com/embed/${savedId}?autoplay=1&mute=1&loop=1&playlist=${savedId}&playsinline=1&rel=0`;
          iframe.setAttribute('data-video-id', savedId);
        }
      });
    }

    // Rotate hero background images every 5 seconds
    const slidesEl = document.getElementById('hero-bg-slides');
    if (slidesEl) {
      const slides = slidesEl.querySelectorAll('.hero-bg-slide');
      const total = slides.length;
      if (total > 1) {
        let current = 0;
        setInterval(() => {
          slides.forEach((s, i) => {
            s.classList.toggle('opacity-100', i === current);
            s.classList.toggle('opacity-0', i !== current);
            s.setAttribute('aria-hidden', i !== current ? 'true' : 'false');
          });
          current = (current + 1) % total;
        }, 5000);
      }
    }

    // Stats counter animation
    const statElements = document.querySelectorAll('[data-stat-value]');
    statElements.forEach((element) => {
      const valueText = element.getAttribute('data-stat-value') || '0';
      const targetValue = parseInt(valueText.replace('+', ''));
      const duration = 2000;
      const steps = 60;
      const stepDuration = duration / steps;
      let currentStep = 0;
      const counterInterval = setInterval(() => {
        currentStep++;
        const progress = currentStep / steps;
        const currentValue = Math.floor(targetValue * progress);
        element.textContent = valueText.includes('+') ? currentValue + '+' : String(currentValue);
        if (currentStep >= steps) {
          clearInterval(counterInterval);
          element.textContent = valueText;
        }
      }, stepDuration);
    });
  });
</script>
