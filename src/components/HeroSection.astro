---
import { getTranslation, type Language } from '../utils/i18n';

interface Props {
  lang?: Language;
}

const { lang = 'ta' } = Astro.props;

// Full-screen hero background (London / Tamil heritage)
const carouselImages = [
  '/static/content/london-skyline-sunset.jpg',
  '/static/content/background-london.jpg',
  '/static/content/london-skyline-colorful.png',
];

// Riyadh-style: 4 stats in a row
const stats = [
  {
    value: '50+',
    label: { ta: 'சேவை ஆண்டுகள்', en: 'Years of Service' }
  },
  {
    value: '400+',
    label: { ta: 'சமூக உறுப்பினர்கள்', en: 'Community Members' }
  },
  {
    value: '1',
    label: { ta: 'பள்ளி இடம்', en: 'School Location' }
  },
  {
    value: '100+',
    label: { ta: 'நிகழ்வுகள்', en: 'Events Organised' }
  }
];
---

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-2 md:pt-4 pb-16 md:pb-20">
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    {carouselImages.map((img, index) => (
      <div
        class={`absolute inset-0 transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        style={`background-image: url(${img}); background-size: cover; background-position: center;`}
      />
    ))}
    <div class="absolute inset-0 hero-overlay" style="background: linear-gradient(to bottom, rgba(200, 75, 50, 0.2) 0%, rgba(160, 55, 45, 0.35) 25%, rgba(80, 35, 30, 0.55) 55%, rgba(25, 18, 18, 0.78) 80%, rgba(12, 10, 10, 0.88) 100%);"></div>
  </div>

  <!-- Riyadh-style: single centered column, no side panels -->
  <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 text-center text-white">
    <!-- Est. badge -->
    <p class="text-sm md:text-base font-medium tracking-[0.2em] uppercase text-white/90 mb-4">
      [ {lang === 'ta' ? 'நிறுவப்பட்டது 1975 · லண்டன், UK' : 'Est. 1975 · London, UK'} ]
    </p>

    <!-- Main title: London Tamil Sangam for SEO + welcome -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-3 leading-tight">
      {lang === 'ta' ? (
        <span class="block font-tamil">வணக்கம்!</span>
      ) : (
        <span class="block">Welcome to London Tamil Sangam</span>
      )}
    </h1>
    <p class="text-xl md:text-2xl font-tamil text-white/95 mb-2">
      {lang === 'ta'
        ? 'லண்டன் தமிழ் சங்கம் – தமிழர் முன்னேற்றக் கழகம் லண்டன் தங்களை அன்புடன் வரவேற்கிறது'
        : 'London Tamil Sangam – TMK London welcomes you'}
    </p>

    <!-- Tagline (bilingual) -->
    <p class="text-base md:text-lg lg:text-xl text-white/90 max-w-3xl mx-auto mb-4 leading-relaxed">
      {lang === 'ta'
        ? '1975 முதல் லண்டனில் தமிழ் மொழி, இலக்கியம் மற்றும் கலாச்சாரத்தை வளர்க்கிறோம்'
        : 'Promoting Tamil language, literature & culture in London since 1975'}
    </p>

    <!-- Inspirational quote (Riyadh-style) -->
    <p class="text-sm md:text-base italic text-white/85 max-w-2xl mx-auto mb-8 md:mb-10">
      "{lang === 'ta'
        ? 'தமிழருடன் தமிழில் பேசி, நம் தாய் மொழியைச் சிறப்பிப்போமாக!'
        : 'Let us speak Tamil with Tamilians and glorify our mother tongue!'}"
    </p>

    <!-- Primary links: About Us | Our Events (Riyadh-style: primary = maroon) -->
    <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6 mb-10 md:mb-12">
      <a
        href={`/about${lang === 'en' ? '?lang=en' : ''}`}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold bg-white/15 backdrop-blur-md border border-white/30 hover:bg-white/25 transition-all text-white"
      >
        {getTranslation('about', lang)}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
      <a
        href="#activities"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold bg-accent text-white border border-accent-dark hover:bg-accent-dark transition-all shadow-lg"
      >
        {lang === 'ta' ? 'எங்கள் நிகழ்வுகள்' : 'Our Events'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>

    <!-- Stats row: 4 cards (Riyadh-style) -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 max-w-4xl mx-auto">
      {stats.map((stat) => (
        <div class="bg-black/35 backdrop-blur-md rounded-2xl p-5 md:p-6 border border-white/15 hover:bg-black/45 transition-all duration-300 hover:scale-[1.02] shadow-lg">
          <div class="text-3xl md:text-4xl lg:text-5xl font-bold text-amber-400" data-stat-value={stat.value}>
            {stat.value}
          </div>
          <div class="text-sm md:text-base text-white/90 font-medium mt-2">{stat.label[lang]}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const statElements = document.querySelectorAll('[data-stat-value]');
    statElements.forEach((element) => {
      const valueText = element.getAttribute('data-stat-value') || '0';
      const targetValue = parseInt(valueText.replace('+', ''));
      const duration = 2000;
      const steps = 60;
      const stepDuration = duration / steps;
      let currentStep = 0;
      const counterInterval = setInterval(() => {
        currentStep++;
        const progress = currentStep / steps;
        const currentValue = Math.floor(targetValue * progress);
        element.textContent = valueText.includes('+') ? currentValue + '+' : String(currentValue);
        if (currentStep >= steps) {
          clearInterval(counterInterval);
          element.textContent = valueText;
        }
      }, stepDuration);
    });
  });
</script>
