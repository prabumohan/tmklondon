            <a href={`/tamil-school${lang === 'en' ? '?lang=en' : ''}`} class={`site-nav-link site-nav-link-has-dropdown ${currentPath.startsWith('/tamil-school') ? 'site-nav-link-active' : ''}`}>
              {getTranslation('tamilSchool', lang)}
