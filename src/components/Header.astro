          </a>
          <div class="relative group">
            <a href={`/gallery${lang === 'en' ? '?lang=en' : ''}`} class={`site-nav-link site-nav-link-has-dropdown ${currentPath === '/gallery' ? 'site-nav-link-active' : ''}`}>
