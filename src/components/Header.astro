<script>
  // Handle both mobile menu buttons
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileNavButton = document.getElementById('mobile-nav-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  mobileNavButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Normalize stored item to { text, priority }
  function normalizeTickerItem(item) {
    if (typeof item === 'string') return { text: item, priority: 'medium' };
    return { text: item.text || '', priority: item.priority || 'medium' };
  }

  function loadNewsTicker() {
    const ticker = document.getElementById('news-ticker');
    if (!ticker) return;

    var stored = localStorage.getItem('newsTickerItems');
    var raw = [];
    if (stored) {
      try {
        var parsed = JSON.parse(stored);
        raw = Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        console.error('Error parsing news items:', e);
      }
    }
    var newsItems = raw.map(normalizeTickerItem).filter(function (x) { return x.text; });

    if (newsItems.length === 0) {
      newsItems = [
        { text: 'Welcome to TMK London - Celebrating Tamil Culture and Heritage', priority: 'high' },
        { text: 'Follow us on social media for the latest updates and events', priority: 'medium' },
        { text: 'Tamil School registration is now open for the new academic year', priority: 'high' },
        { text: 'Join us for our upcoming cultural events and celebrations', priority: 'medium' }
      ];
    }

    var items = newsItems.concat(newsItems);
    ticker.innerHTML = items.map(function (item, index) {
      var isLast = index === items.length - 1;
      var isLatest = index % newsItems.length === 0;
      var priorityClass = 'ticker-priority-' + item.priority;
      var latestClass = isLatest ? ' ticker-latest' : '';
      var spanClass = 'text-sm ' + priorityClass + latestClass;
      var div = document.createElement('div');
      div.textContent = item.text;
      var text = div.innerHTML;
      return '<span class="' + spanClass + '">' + text + '</span>' + (!isLast ? '<span class="text-gray-400">•</span>' : '');
    }).join('');
  }

  loadNewsTicker();

  // Same-tab: admin dispatches this when saving
  window.addEventListener('newsTickerUpdated', loadNewsTicker);

  // Other tab: storage event when admin saves elsewhere
  window.addEventListener('storage', function (e) {
    if (e.key === 'newsTickerItems') loadNewsTicker();
  });

  // Fallback poll every 8s so ticker updates without refresh (e.g. after admin save in same tab in some edge cases)
  setInterval(loadNewsTicker, 8000);
</script>
