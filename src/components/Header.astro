---
import { getTranslation, type Language } from '../utils/i18n';
import { siteConfig } from '../utils/seo';

interface Props {
  lang?: Language;
}

// Extract language from URL query parameter first, then fall back to props
const urlLang = Astro.url.searchParams.get('lang') as Language;
const { lang: propLang = 'ta' } = Astro.props;
const lang = urlLang || propLang;
const currentPath = Astro.url.pathname;
const currentUrl = Astro.url;

// Helper function to get URL with language parameter
function getUrlWithLang(langParam: Language): string {
  const url = new URL(currentUrl);
  url.searchParams.set('lang', langParam);
  return url.pathname + (url.search ? url.search : '');
}

// Header: use paths that exist in repo (public/logo.png; static/ may be untracked on deploy)
const headerBgImage = '/static/content/header-carousel/fiery_sunset_sky_swirling-full.jpg';
const logoUrl = '/logo.png';
---

<header class="fixed top-0 left-0 right-0 w-full z-[100] shadow-lg bg-transparent header-fixed-lts" id="site-header">
  <!-- Header Banner: background image with gradient fallback if image 404s -->
  <div class="relative min-h-[100px] md:min-h-[110px] header-banner-custom overflow-hidden" style="background: linear-gradient(135deg, #6B2D3C 0%, #5C1A1B 50%, #451a1a 100%);">
    <img
      src={headerBgImage}
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center pointer-events-none"
      loading="eager"
      decoding="async"
    />
    <div class="relative z-10 w-full px-3 sm:px-4 md:px-6 lg:px-8">
      <div class="header-banner-row flex flex-nowrap items-center justify-between gap-2 sm:gap-3 md:gap-6 py-2.5 sm:py-3 md:py-4 min-h-[100px] sm:min-h-[110px] md:min-h-[140px]">
        <!-- 1. Logo (left) – slightly smaller on mobile for breathing room -->
        <a href="/" class="header-logo flex-shrink-0 mr-1 sm:mr-2 md:mr-4 group animate-fade-in-left">
          <div class="relative logo-modern-wrap">
            <div class="absolute inset-0 bg-white rounded-full shadow-md ring-1 ring-gray-200/80 transition-all duration-300 group-hover:shadow-lg group-hover:ring-primary-200"></div>
            <div class="absolute -inset-0.5 bg-primary-100/40 rounded-full blur-md transition-opacity duration-300 group-hover:bg-primary-50/60"></div>
            <img src={logoUrl} alt="TMK London" class="relative logo-modern-img h-20 w-20 sm:h-24 sm:w-24 md:h-36 md:w-36 lg:h-44 lg:w-44 rounded-full object-cover transition-transform duration-300 ease-out group-hover:scale-105" />
          </div>
        </a>

        <!-- 2. Name (center) – clean; text shadow for readability, no box -->
        <a href="/" class="header-name flex-1 flex items-center justify-center text-center min-w-0 px-1 sm:px-2 md:px-4 group ring-0 border-0 outline-none focus:ring-0 focus:outline-none focus:border-0">
          <div class="header-name-block animate-name-fall w-full max-w-none min-w-0 pt-1.5 pb-1 px-2 sm:pt-2 sm:pb-1.5 md:pt-2.5 md:pb-2 md:px-3 overflow-visible">
            <!-- Main title: multi-colour gradient – readable on bright bg with shadow -->
            {lang === 'ta' ? (
              <div class="name-title name-title-gradient text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-bold font-tamil leading-tight sm:leading-relaxed mb-0.5 sm:mb-1 md:mb-1.5 tracking-wide">
                தமிழர் முன்னேற்றக் கழகம்
              </div>
            ) : (
              <div class="name-title name-title-gradient text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-bold leading-tight sm:leading-snug mb-0.5 sm:mb-1 md:mb-1.5 tracking-wide">
                Thamizhar Munnetra Kazhagam
              </div>
            )}
            <!-- English subtitle: hidden on smallest mobile to reduce clutter -->
            <div class="name-subtitle-gradient hidden sm:block text-[10px] md:text-xs lg:text-sm font-bold tracking-[0.15em] md:tracking-[0.2em] uppercase mb-0.5 md:mb-1 letter-spread">
              THAMIZHAR MUNNETRA KAZHAGAM
            </div>
            <div class="header-name-tagline text-[9px] sm:text-[10px] md:text-xs font-medium tracking-wide leading-snug sm:leading-relaxed text-white">
              {lang === 'ta' ? 'தமிழ் சமூகம் மற்றும் கல்வி மையம் · நிறுவப்பட்டது 1975' : 'Tamil Community & Education Center · Estd. 1975'}
            </div>
          </div>
        </a>

        <!-- 3. Contact + Social – desktop: full card; mobile: compact icons -->
        <div class="header-contact flex flex-shrink-0 ml-auto justify-end animate-fade-in-right">
          <!-- Desktop: full contact card -->
          <div class="contact-card hidden md:flex flex-col gap-2 p-2.5 min-w-[200px]">
            <!-- Phone & Email -->
            <div class="flex flex-col gap-1">
              <a href={`tel:${siteConfig.contact.phone}`} class="flex items-center gap-2 px-1.5 py-1.5 rounded-md hover:opacity-90 transition-all">
                <span class="flex h-6 w-6 md:h-7 md:w-7 shrink-0 items-center justify-center rounded text-white [text-shadow:0_1px_2px_rgba(0,0,0,0.8)]">
                  <svg class="w-3.5 h-3.5 md:w-4 md:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </span>
                <span class="text-xs md:text-sm font-bold text-white truncate [text-shadow:0_1px_3px_rgba(0,0,0,0.9)]">{siteConfig.contact.phone}</span>
