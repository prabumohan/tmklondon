            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation Bar – moved up, new style, responsive (visible from md up) -->
  <nav class="site-nav site-nav-desktop hidden md:flex text-white z-50 -mt-px" aria-label="Main navigation">
    <div class="site-nav-inner container mx-auto px-3 sm:px-4 md:px-5 lg:px-6 w-full">
      <div class="flex items-stretch justify-between gap-2 py-2 md:py-2.5 min-h-[48px]">
        <div class="flex items-center gap-0.5 sm:gap-1 overflow-x-auto scrollbar-hide flex-1 min-w-0">
          <a href={`/${lang === 'en' ? '?lang=en' : ''}`} class={`site-nav-link ${currentPath === '/' ? 'site-nav-link-active' : ''}`}>
            {getTranslation('home', lang)}
