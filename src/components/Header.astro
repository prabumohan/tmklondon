<style>
  /* Fixed header + menu like lts-bqd.pages.dev – stays at top when scrolling */
  #site-header.header-fixed-lts {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    z-index: 100 !important;
    background-color: transparent;
  }

  /* LTS-style header: logo left, name centered in middle, contact+social right */
  .header-banner-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
  }
  .header-banner-row .header-logo {
    flex: 0 0 auto;
  }
  /* Modern logo: lighter, brighter presentation */
  .logo-modern-wrap {
    isolation: isolate;
  }
  .logo-modern-img {
    filter: brightness(1.12) contrast(1.05) saturate(0.95);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }
  .header-logo:hover .logo-modern-img {
    filter: brightness(1.15) contrast(1.06) saturate(1);
  }
  .header-banner-row .header-name {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    border: none;
    outline: none;
    box-shadow: none;
  }
  .header-name-block {
    line-height: 1.3;
    overflow: visible;
    box-shadow: none;
    background: none;
    border: none;
    outline: none;
  }
  /* Prevent Tamil/script glyphs from being clipped (ascenders, loops) */
  .header-name-block .name-title {
    padding-top: 0.15em;
    padding-bottom: 0.05em;
  }
  .header-name-block .letter-spread {
    letter-spacing: 0.2em;
  }
  @media (min-width: 768px) {
    .header-name-block .letter-spread {
      letter-spacing: 0.28em;
    }
  }

  /* Multi-colour gradient text: main title (cream → saffron → amber). Fallback light color so never black. */
  .name-title-gradient {
    color: #fefce8;
    background: linear-gradient(105deg, #fefce8 0%, #fde68a 25%, #fbbf24 50%, #f59e0b 75%, #d97706 100%);
    background-size: 200% auto;
    background-position: 0% center;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background-position 0.6s ease;
  }
  .group:hover .name-title-gradient {
    background-position: 100% center;
  }

  /* Subtitle: light gradient (cream → saffron). Fallback light color so never black. */
  .name-subtitle-gradient {
