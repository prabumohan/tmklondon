---
interface Props {
  date: string;
  title: {
    ta: string;
    en: string;
  };
  description: {
    ta: string;
    en: string;
  };
  lang?: 'ta' | 'en';
}

const { date, title, description, lang = 'ta' } = Astro.props;
---

<div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100 hover:border-primary-200">
  <div class="p-6">
    <div class="flex items-center mb-3">
      <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mr-3">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <div class="text-sm text-primary-600 font-semibold">{date}</div>
    </div>
    <h3 class="text-xl font-bold mb-3 text-gray-900 font-tamil">{title[lang]}</h3>
    <p class="text-gray-600 mb-4 font-tamil leading-relaxed">{description[lang]}</p>
    <a href="#activities" class="text-primary-600 hover:text-primary-700 font-semibold inline-flex items-center group">
      {lang === 'ta' ? 'மேலும் அறிய' : 'Learn More'}
      <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>
